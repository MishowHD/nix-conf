{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "ignoreTests": true,
  "minimumReleaseAge": "3 days",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "automerge": false,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "flake",
  "commitBody": "Updated:\n{{#each upgrades}}\n- {{depName}}: {{currentVersion}} -> {{newVersion}}\n{{/each}}",
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["nix"],
      "matchPackageNames": ["nixpkgs", "nixos-unstable"],
      "groupName": "nixpkgs core",
      "automerge": false,
      "schedule": ["before 5am on monday"]
    },
    {
      "matchManagers": ["nix"],
      "matchUpdateTypes": [
        "lockFileMaintenance",
        "digest",
        "pin",
        "patch",
        "minor"
      ],
      "excludePackageNames": ["nixpkgs", "nixos-unstable"],
      "groupName": "flake inputs",
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
